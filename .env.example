NODE_ENV=development

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather

# Optional: override Telegram Bot API base URL.
# - Default (empty): use official Telegram servers at https://api.telegram.org (50MB file limit).
# - For self-hosted telegram-bot-api (see docker-compose.yml): http://telegram-bot-api:8081
# TELEGRAM_API_BASE=https://api.telegram.org

# Optional: max video size (in MB) that this bot will try to upload.
# - Default: 50 (matches official Telegram Bot API limit).
# - When using a self-hosted telegram-bot-api server, you can increase up to ~2000.
# TELEGRAM_MAX_VIDEO_MB=50

# Required ONLY when running a self-hosted telegram-bot-api server (see docker-compose.yml).
# Get these from https://my.telegram.org/apps
# TELEGRAM_API_ID=your_telegram_api_id
# TELEGRAM_API_HASH=your_telegram_api_hash

# TikTok downloader configuration
# Path to external downloader binary (default: yt-dlp)
# TIKTOK_DOWNLOADER_BIN=yt-dlp

# Optional extra args for downloader (split on spaces). Default: -o %(id)s.%(ext)s --merge-output-format mp4
# Example: --no-playlist --restrict-filenames
# TIKTOK_DOWNLOADER_ARGS=-o %(id)s.%(ext)s --merge-output-format mp4 --no-playlist

# JS runtime for yt-dlp (e.g. "node") to reduce YouTube "No supported JavaScript runtime" warnings
# and get full format list. Uses this app's Node executable. Leave unset to disable.
# TIKTOK_DOWNLOADER_JS_RUNTIMES=node

# Video cache
# DATA_DIR=./data    (default ./data, used for video cache under DATA_DIR/cache)
# CACHE_MAX_MB=1024  (default 1024 MB). Oldest cached files are evicted when above this size.
DATA_DIR=./data

# Webhook mode (optional). If TELEGRAM_WEBHOOK_URL is set, bot uses webhook instead of long-poll.
# Base URL Telegram will POST to (bot uses path /webhook). Must be HTTPS in production.
# TELEGRAM_WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PORT=3000
# WEBHOOK_SECRET=optional_secret_token_for_X-Telegram-Bot-Api-Secret-Token
