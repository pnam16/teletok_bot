{
  "name": "teletok-bot",
  "version": "1.0.0",
  "description": "Teletok: Telegram bot that reuploads TikTok videos into a chat",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "check": "node src/index.js --once",
    "dev": "node src/index.js",
    "docker": "docker compose up -d --build",
    "lint": "pnpm exec biome check --write",
    "pm2": "pm2 start ecosystem.config.cjs --update-env",
    "start:envfile": "node --env-file=.env dist/index.js",
    "start": "node dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "esbuild": "^0.24.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
